<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sahara.controller.CaregiverDashboardController"
            prefWidth="1050.0" prefHeight="680.0">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1A5276; -fx-padding: 14 24 14 24;">
            <Label text="Sahara"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="|" style="-fx-text-fill: #5D8AA8; -fx-font-size: 18px;"/>
            <Label text="Caregiver Dashboard"
                   style="-fx-font-size: 14px; -fx-text-fill: #AED6F1;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel"
                   style="-fx-font-size: 13px; -fx-text-fill: white;"/>
            <Button fx:id="notificationBellBtn" text="🔔" onAction="#handleNotifications"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18px; -fx-padding: 4 10 4 10; -fx-cursor: hand;"/>
            <Button text="Log Out" onAction="#handleLogout"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 16 6 16; -fx-background-radius: 4;"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <Tab text="Booking Requests">
                <VBox spacing="14" style="-fx-background-color: #F4F6F9; -fx-padding: 16 20 16 20;">
                    <Label text="Incoming Booking Requests"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A5276;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 6;">
                        <Button text="Refresh" onAction="#handleRefreshRequests"
                                style="-fx-background-color: #2E86C1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                        <Button text="View Details" onAction="#handleViewRequestDetails"
                                style="-fx-background-color: #5D6D7E; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Accept" onAction="#handleAccept"
                                style="-fx-background-color: #1E8449; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                        <Button text="Decline" onAction="#handleDecline"
                                style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                    </HBox>
                    <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="reqColId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="reqColPatient" text="Patient" prefWidth="160"/>
                            <TableColumn fx:id="reqColHospital" text="Hospital" prefWidth="160"/>
                            <TableColumn fx:id="reqColAdmission" text="Admission" prefWidth="110"/>
                            <TableColumn fx:id="reqColDischarge" text="Discharge" prefWidth="110"/>
                            <TableColumn fx:id="reqColCost" text="Cost (NPR)" prefWidth="110"/>
                        </columns>
                        <placeholder>
                            <Label text="No pending requests right now."/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Active Assignments">
                <VBox spacing="14" style="-fx-background-color: #F4F6F9; -fx-padding: 16 20 16 20;">
                    <Label text="Your Active Assignments"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A5276;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 6;">
                        <Button text="Refresh" onAction="#handleRefreshActive"
                                style="-fx-background-color: #2E86C1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                        <Button text="View Details" onAction="#handleViewActiveDetails"
                                style="-fx-background-color: #5D6D7E; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                    </HBox>
                    <TableView fx:id="activeTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="actColId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="actColPatient" text="Patient" prefWidth="160"/>
                            <TableColumn fx:id="actColHospital" text="Hospital" prefWidth="160"/>
                            <TableColumn fx:id="actColAdmission" text="Admission" prefWidth="110"/>
                            <TableColumn fx:id="actColDischarge" text="Discharge" prefWidth="110"/>
                            <TableColumn fx:id="actColCost" text="Cost (NPR)" prefWidth="110"/>
                        </columns>
                        <placeholder>
                            <Label text="No active assignments right now."/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Completed History">
                <VBox spacing="14" style="-fx-background-color: #F4F6F9; -fx-padding: 16 20 16 20;">
                    <Label text="Completed Assignment History"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A5276;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 6;">
                        <Button text="Refresh" onAction="#handleRefreshCompleted"
                                style="-fx-background-color: #2E86C1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                        <Button text="View Details" onAction="#handleViewCompletedDetails"
                                style="-fx-background-color: #5D6D7E; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                    </HBox>
                    <TableView fx:id="completedTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="compColId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="compColPatient" text="Patient" prefWidth="160"/>
                            <TableColumn fx:id="compColHospital" text="Hospital" prefWidth="160"/>
                            <TableColumn fx:id="compColAdmission" text="Admission" prefWidth="110"/>
                            <TableColumn fx:id="compColDischarge" text="Discharge" prefWidth="110"/>
                            <TableColumn fx:id="compColCost" text="Cost (NPR)" prefWidth="110"/>
                        </columns>
                        <placeholder>
                            <Label text="No completed assignments yet."/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Availability">
                <VBox spacing="14" style="-fx-background-color: #F4F6F9; -fx-padding: 16 20 16 20;">
                    <Label text="Set Your Availability"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A5276;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 6;">
                        <Label text="Pick a date:"/>
                        <DatePicker fx:id="availabilityDatePicker"/>
                        <Button text="Add Date" onAction="#handleAddAvailability"
                                style="-fx-background-color: #1E8449; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Toggle Status" onAction="#handleToggleAvailability"
                                style="-fx-background-color: #8E44AD; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                        <Button text="Remove Selected" onAction="#handleRemoveAvailability"
                                style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                        <Button text="Refresh" onAction="#handleRefreshAvailability"
                                style="-fx-background-color: #2E86C1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 18 6 18; -fx-background-radius: 4;"/>
                    </HBox>
                    <TableView fx:id="availabilityTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="availColDate" text="Date" prefWidth="200"/>
                            <TableColumn fx:id="availColStatus" text="Status" prefWidth="200"/>
                        </columns>
                        <placeholder>
                            <Label text="You haven't added any availability dates yet."/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="My Profile">
                <VBox spacing="18" style="-fx-background-color: #F4F6F9; -fx-padding: 20 24 20 24;">
                    <Label text="My Profile"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A5276;"/>

                    <GridPane hgap="12" vgap="12"
                              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 6;">
                        <Label text="Name:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="profileNameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Gender:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="profileGenderLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Age:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="profileAgeLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Average Rating:" style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="profileRatingLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Experience (years):" style="-fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <TextField fx:id="profileExperienceField" prefWidth="120" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="Bio:" style="-fx-font-weight: bold;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <TextArea fx:id="profileBioArea" prefRowCount="3" wrapText="true" prefWidth="400" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                        <Button text="Save Changes" onAction="#handleSaveProfile"
                                style="-fx-background-color: #1E8449; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-background-radius: 4;"
                                GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                    </GridPane>

                    <Label text="Patient Feedback"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A5276;"/>
                    <ListView fx:id="feedbackListView" prefHeight="150" VBox.vgrow="ALWAYS"/>

                    <Label text="Change Password"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A5276;"/>
                    <GridPane hgap="12" vgap="12"
                              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 6;">
                        <Label text="Current Password:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="currentPasswordField" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="New Password:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="newPasswordField" prefWidth="220" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Confirm New Password:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="confirmNewPasswordField" prefWidth="220" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label fx:id="passwordChangeErrorLabel" textFill="RED" wrapText="true" maxWidth="300"
                               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Button text="Change Password" onAction="#handleChangePassword"
                                style="-fx-background-color: #8E44AD; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-background-radius: 4;"
                                GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>