<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sahara.controller.DashboardController"
      alignment="CENTER" spacing="14.0" prefWidth="420.0" prefHeight="320.0">

    <padding>
        <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
    </padding>

    <Label text="Caregiver Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Label fx:id="welcomeLabel" style="-fx-font-size: 16px;"/>
    <Label fx:id="roleLabel" style="-fx-text-fill: #666666;"/>

    <Label text="Coming soon: complete your profile, set availability, and view bookings. (New accounts await admin verification.)"
           wrapText="true" textFill="#888888" maxWidth="Infinity"/>

    <Button text="Log Out" onAction="#handleLogout" maxWidth="Infinity"
            style="-fx-padding: 8 0 8 0;"/>
</VBox>
