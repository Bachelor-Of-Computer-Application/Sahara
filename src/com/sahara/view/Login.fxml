<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sahara.controller.LoginController"
      alignment="CENTER" spacing="10.0" prefWidth="380.0" prefHeight="480.0">

    <padding>
        <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
    </padding>

    <Label text="Sahara" style="-fx-font-size: 32px; -fx-font-weight: bold;"/>
    <Label text="Hospital Caregiver Request System"
           style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>

    <Label text="Email" style="-fx-font-weight: bold;" maxWidth="Infinity"/>
    <TextField fx:id="emailField" promptText="you@example.com"/>
    <Label fx:id="emailErrorLabel" textFill="RED" wrapText="true" maxWidth="Infinity"
           style="-fx-font-size: 11px;"/>

    <Label text="Password" style="-fx-font-weight: bold;" maxWidth="Infinity"/>
    <HBox spacing="6" alignment="CENTER_LEFT">
        <StackPane HBox.hgrow="ALWAYS">
            <PasswordField fx:id="passwordField" promptText="Your password" maxWidth="Infinity"/>
            <TextField fx:id="passwordVisibleField" promptText="Your password" maxWidth="Infinity"
                       managed="false" visible="false"/>
        </StackPane>
        <Button fx:id="togglePasswordBtn" text="👁" onAction="#handleTogglePassword"
                style="-fx-padding: 4 10 4 10;"/>
    </HBox>
    <Label fx:id="passwordErrorLabel" textFill="RED" wrapText="true" maxWidth="Infinity"
           style="-fx-font-size: 11px;"/>

    <Label fx:id="messageLabel" wrapText="true" textFill="RED" maxWidth="Infinity"/>

    <Button fx:id="loginButton" text="Log In" onAction="#handleLogin"
            defaultButton="true" maxWidth="Infinity"
            style="-fx-font-size: 14px; -fx-padding: 8 0 8 0;"/>

    <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"/>

    <Hyperlink text="Don't have an account? Register here"
               onAction="#goToRegister"/>

</VBox>